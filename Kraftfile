specification: v0.6
outdir: ./out
name: bob

unikraft:
  version: stable
  kconfig:
    CONFIG_LIBUKFS_VIRTIOFS: 'y'
    CONFIG_LIBUKFS_VIRTIOFS_IOMEM: 'y'
    CONFIG_LIBUKFS_VIRTIOFS_RAMFS: 'y'
    CONFIG_VIRTIO_MMIO_LINUX_COMPAT_CMDLINE: 'y'
    CONFIG_LIBUKFS_RAMFS: 'y'
    CONFIG_LIBUKFS_DEVFS: 'y'

volumes: /tmp/shared:/

libraries:
  musl: staging

targets:
  - name: bob
    architecture: x86_64
    platform: kvm
